XHCI: don't reject isochronous endpoints with wMaxPacketSize=0

BT and USB Audio devices use Interface 1 Alt 0 as a zero-bandwidth
placeholder (wMaxPacketSize=0 on isoc endpoints).  ConfigureEndpoint
bails because max_burst_payload ends up 0 — but this is valid per
XHCI 1.2 § 4.14.1.1.  Let isoc endpoints through with mbp=1 to
avoid div-by-zero in TRB sizing, guard AVGTRBLENGTH/MAXESITPAYLOAD.

--- a/src/add-ons/kernel/busses/usb/xhci.cpp
+++ b/src/add-ons/kernel/busses/usb/xhci.cpp
@@ -2275,8 +2275,16 @@
 	// The Max Burst Payload is the number of bytes moved by a
 	// maximum sized burst. (XHCI 1.2 § 4.11.7.1 p236.)
 	ep->max_burst_payload = (maxBurst + 1) * maxPacketSize;
-	if (ep->max_burst_payload == 0) {
-		TRACE_ERROR("ConfigureEndpoint() failed invalid max_burst_payload\n");
+	if (ep->max_burst_payload == 0
+			&& (type & USB_OBJECT_ISO_PIPE) != 0) {
+		// Zero-bandwidth isochronous alternate setting (e.g. Bluetooth
+		// USB Interface 1 Alt 0 with wMaxPacketSize=0).  Valid per USB
+		// spec; XHCI 1.2 section 4.14.1.1 allows Max Packet Size = 0
+		// in the endpoint context for these.  Set to 1 to avoid
+		// division-by-zero in TRB size calculations.
+		ep->max_burst_payload = 1;
+	} else if (ep->max_burst_payload == 0) {
+		TRACE_ERROR("ConfigureEndpoint() failed invalid max_burst_payload\n");
 		return B_BAD_VALUE;
 	}

@@ -2288,7 +2296,8 @@
 		// Isochronous pipes are another special case: the TRB size will be
 		// one packet (which is normally smaller than the max packet size,
 		// but we don't know what it is here.)
-		dwendpoint4 |= ENDPOINT_4_AVGTRBLENGTH(maxPacketSize);
+		if (maxPacketSize > 0)
+			dwendpoint4 |= ENDPOINT_4_AVGTRBLENGTH(maxPacketSize);
 	} else {
 		// Under all other circumstances, we put max_burst_payload in a TRB.
 		dwendpoint4 |= ENDPOINT_4_AVGTRBLENGTH(ep->max_burst_payload);
@@ -2301,10 +2310,14 @@
 		// We don't fetch this yet, so just fall back to the USB2 computation
 		// method if bytesPerInterval is 0.
-		if (speed >= USB_SPEED_SUPERSPEED && bytesPerInterval != 0)
+		if (speed >= USB_SPEED_SUPERSPEED && bytesPerInterval != 0) {
 			dwendpoint4 |= ENDPOINT_4_MAXESITPAYLOAD(bytesPerInterval);
-		else if (speed >= USB_SPEED_HIGHSPEED)
-			dwendpoint4 |= ENDPOINT_4_MAXESITPAYLOAD((maxBurst + 1) * maxPacketSize);
+		} else if (speed >= USB_SPEED_HIGHSPEED) {
+			// Skip for zero-bandwidth isochronous alternate settings
+			// where maxPacketSize is 0.
+			if (maxPacketSize > 0)
+				dwendpoint4 |= ENDPOINT_4_MAXESITPAYLOAD(
+					(maxBurst + 1) * maxPacketSize);
+		}
 	}

 	_WriteContext(&device->input_ctx->endpoints[number].dwendpoint0,
